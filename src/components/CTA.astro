---
import { copy, href, type Lang } from '../data/site';
const { lang } = Astro.props as { lang: Lang };
const t = copy[lang].cta;
---
<section class="cta">
  <div class="container cta__grid" data-reveal>
    <p class="eyebrow">{t.eyebrow}</p>
    <h2>{t.title}</h2>
    <div><p>{t.body}</p><a class="button" href={href(lang, 'contact/')}>{t.button}</a></div>
  </div>
</section>
<style>
  .cta { padding: clamp(90px, 12vw, 160px) 0; background: var(--paper-deep); }
  .cta__grid { display: grid; grid-template-columns: 1.2fr 2fr 1fr; gap: 40px; align-items: start; }
  .cta .eyebrow { margin: 12px 0 0; }
  .cta h2 { max-width: 660px; margin: 0; font-family: var(--serif); font-size: clamp(2.8rem, 5.6vw, 5.8rem); font-weight: 300; letter-spacing: -.045em; line-height: .95; }
  .cta__grid > div p { margin: 8px 0 30px; color: var(--muted); font-size: .88rem; }
  @media (max-width: 840px) { .cta__grid { grid-template-columns: 1fr; } .cta .eyebrow { margin: 0; } }
</style>
