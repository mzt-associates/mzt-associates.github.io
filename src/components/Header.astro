---
import { copy, href, type Lang } from '../data/site';
interface Props { lang: Lang; path?: string; theme?: 'light' | 'dark'; }
const { lang, path = '', theme = 'light' } = Astro.props;
const t = copy[lang];
const other: Lang = lang === 'ja' ? 'en' : 'ja';
const serviceLinks = [
  ['bird-in-hand', t.services['bird-in-hand'].name],
  ['fire-control', t.services['fire-control'].name],
  ['kiwas-trading', t.services['kiwas-trading'].name],
];
const langPath = path ? href(other, path) : href(other);
---
<header class:list={['site-header', `site-header--${theme}`]}>
  <a class="brand" href={href(lang)} aria-label="MZT & Associates home">
    <span class="brand__mark">MZT</span>
    <span class="brand__name">& Associates</span>
  </a>
  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
    <span class="sr-only">{lang === 'ja' ? 'メニュー' : 'Menu'}</span><span></span><span></span>
  </button>
  <nav id="site-nav" class="site-nav" aria-label={lang === 'ja' ? 'メインナビゲーション' : 'Main navigation'}>
    <a href={href(lang)}>{t.nav.home}</a>
    <a href={href(lang, 'atelier-lemon/')}>{t.nav.atelier}</a>
    <div class="nav-services">
      <button type="button" aria-expanded="false">{t.nav.services}<span>＋</span></button>
      <div class="nav-services__menu">
        {serviceLinks.map(([slug, name]) => <a href={href(lang, `services/${slug}/`)}>{name}</a>)}
      </div>
    </div>
    <a href={href(lang, 'contact/')}>{t.nav.contact}</a>
    <a class="language" href={langPath} hreflang={other}>{other === 'ja' ? 'JP' : 'EN'}</a>
  </nav>
</header>

<script>
  const header = document.querySelector('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const nav = document.querySelector<HTMLElement>('.site-nav');
  const serviceButton = document.querySelector<HTMLButtonElement>('.nav-services button');

  const closeMenu = () => {
    toggle?.setAttribute('aria-expanded', 'false');
    serviceButton?.setAttribute('aria-expanded', 'false');
    header?.classList.remove('menu-open');
    document.documentElement.classList.remove('menu-open');
  };

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    header?.classList.toggle('menu-open', !open);
    document.documentElement.classList.toggle('menu-open', !open);
  });
  serviceButton?.addEventListener('click', () => {
    const open = serviceButton.getAttribute('aria-expanded') === 'true';
    serviceButton.setAttribute('aria-expanded', String(!open));
  });
  nav?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMenu();
  });
</script>

<style>
  .site-header { position: absolute; z-index: 20; top: 0; left: 0; display: grid; width: 100%; min-height: 96px; padding: 0 max(24px, calc((100vw - 1280px) / 2)); grid-template-columns: 260px 1fr; align-items: center; border-bottom: 1px solid rgba(255,255,255,.28); color: white; }
  .site-header--dark { background: linear-gradient(180deg, rgba(16, 20, 16, .62), rgba(16, 20, 16, .32)); backdrop-filter: blur(10px) saturate(.82); -webkit-backdrop-filter: blur(10px) saturate(.82); }
  .site-header--light { position: relative; border-color: var(--line); color: var(--ink); }
  .brand { display: flex; align-items: baseline; gap: 8px; }
  .brand__mark { font-family: var(--serif); font-size: 1.85rem; letter-spacing: -.05em; line-height: 1; }
  .brand__name { font-size: .67rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; }
  .site-nav { display: flex; align-items: center; justify-content: flex-end; gap: clamp(22px, 3vw, 50px); }
  .site-nav > a, .nav-services > button { padding: 38px 0; border: 0; background: transparent; color: inherit; cursor: pointer; font-size: .69rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; }
  .site-nav > a, .nav-services > button { position: relative; }
  .site-nav > a::after, .nav-services > button::after { position: absolute; right: 0; bottom: 30px; left: 0; height: 1px; background: currentColor; content: ''; transform: scaleX(0); transform-origin: right; transition: transform .25s; }
  .site-nav > a:hover::after, .site-nav > a:focus-visible::after, .nav-services > button:hover::after { transform: scaleX(1); transform-origin: left; }
  .language { opacity: .66; }
  .site-header--dark .language { padding: 9px 13px; border: 1px solid rgba(255,255,255,.52); background: rgba(18,22,18,.42); opacity: 1; line-height: 1; }
  .site-header--dark .language::after { display: none; }
  .site-header--dark .language:hover, .site-header--dark .language:focus-visible { background: var(--paper); color: var(--ink); }
  .nav-services { position: relative; }
  .nav-services button span { margin-left: 6px; }
  .nav-services__menu { position: absolute; top: 78px; left: -20px; display: grid; width: 190px; padding: 14px 20px; background: var(--paper); box-shadow: 0 18px 45px rgba(23,25,21,.13); color: var(--ink); opacity: 0; pointer-events: none; transform: translateY(-6px); transition: opacity .2s, transform .2s; }
  .nav-services__menu a { padding: 10px 0; border-bottom: 1px solid var(--line); font-size: .72rem; }
  .nav-services__menu a:last-child { border: 0; }
  .nav-services:focus-within .nav-services__menu, .nav-services:hover .nav-services__menu { opacity: 1; pointer-events: auto; transform: none; }
  .menu-toggle { display: none; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  @media (max-width: 840px) {
    .site-header { min-height: 78px; padding-inline: 20px; grid-template-columns: 1fr auto; }
    .site-header--dark { backdrop-filter: none; -webkit-backdrop-filter: none; }
    .brand { position: relative; z-index: 2; }
    .menu-toggle { z-index: 2; display: grid; width: 44px; height: 44px; padding: 12px 8px; border: 0; background: transparent; align-content: center; gap: 7px; }
    .menu-open .brand, .menu-open .menu-toggle { color: var(--ink); }
    .menu-toggle span:not(.sr-only) { display: block; height: 1px; background: currentColor; transition: transform .2s; }
    .menu-open .menu-toggle span:nth-last-child(2) { transform: translateY(4px) rotate(45deg); }
    .menu-open .menu-toggle span:last-child { transform: translateY(-4px) rotate(-45deg); }
    .site-nav { position: fixed; z-index: 1; inset: 0; display: flex; width: 100vw; height: 100vh; height: 100dvh; padding: calc(100px + env(safe-area-inset-top)) 28px calc(32px + env(safe-area-inset-bottom)); overflow-y: auto; overscroll-behavior: contain; background: var(--paper); color: var(--ink); flex-direction: column; align-items: stretch; justify-content: flex-start; gap: 0; opacity: 0; pointer-events: none; transform: translateY(-14px); transition: opacity .2s, transform .2s; }
    .menu-open .site-nav { opacity: 1; pointer-events: auto; transform: none; }
    .site-nav > a, .nav-services > button { display: flex; width: 100%; padding: 18px 0; border-bottom: 1px solid var(--line); justify-content: space-between; font-family: var(--serif); font-size: 1.8rem; font-weight: 300; letter-spacing: -.02em; text-align: left; text-transform: none; }
    .site-nav > a::after, .nav-services > button::after { display: none; }
    .nav-services__menu { position: static; display: none; width: 100%; padding: 0 0 0 18px; background: transparent; box-shadow: none; opacity: 1; pointer-events: auto; transform: none; }
    .nav-services button[aria-expanded='true'] + .nav-services__menu { display: grid; }
    .nav-services__menu a { display: block; padding: 10px 0; font-size: .8rem; }
    .language, .site-header--dark .language { width: fit-content !important; margin-top: 18px; padding: 10px 14px !important; border: 1px solid var(--ink) !important; background: transparent; color: var(--ink); font-family: var(--sans) !important; font-size: .75rem !important; font-weight: 600 !important; letter-spacing: .12em !important; }
    :global(html.menu-open), :global(html.menu-open body) { overflow: hidden; }
  }
</style>
